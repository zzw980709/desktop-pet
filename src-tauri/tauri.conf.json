{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-pet",
  "version": "0.1.0",
  "identifier": "com.desktop-pet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Desktop Pet",
        "width": 64,
        "height": 64,
        "transparent": true,
        "shadow": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "skipTaskbar": true,
        "acceptFirstMouse": true,
        "maximizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:18920",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/.petdex/pets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Entertainment",
    "targets": ["nsis", "dmg", "app", "appimage", "deb", "rpm"],
    "shortDescription": "Desktop Pet",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-pet",
  "version": "0.1.0",
  "identifier": "com.desktop-pet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Desktop Pet",
        "width": 64,
        "height": 64,
        "transparent": true,
        "shadow": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
